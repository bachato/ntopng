			"width" : 4,
			"height" : 4,
			"requires" : {
				"modules" : [ "l7_timeseries" ]
			},
			"params" : {
				"url" : "/lua/rest/v2/get/interface/l7/stats.lua",
				"url_params" : {
					"breed" : "true",
					"ndpistats_mode" : "count"
				},
				"unit": "number",
				"label": "flows"
			}
		},
		{
			"component" : "pie",
			"id" : "traffic_classification",
			"i18n_name" : "dashboard.classification",
