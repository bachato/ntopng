				"url_params" : {
                    "interface_role":"ix"
                },
				"unit" : "bytes",
				"label_key" : "interface_name",
				"value_key" : "total_bytes"
			}
		},
        {
			"component" : "pie",
			"id" : "top_peering_exporters_interfaces",
