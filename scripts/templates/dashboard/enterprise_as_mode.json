			"id" : "top_transit_exporters_interfaces",
			"i18n_name" : "dashboard.asn_dashboard.top_transit_exporter_interfaces",
			"width" : 4,
			"height" : 4,
			"params" : {
				"url" : "/lua/pro/rest/v2/get/flowdevices/get_top_exporters_interfaces.lua",
