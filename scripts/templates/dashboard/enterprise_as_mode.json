				"source_type": "interface"
			}
		},

        {
			"component" : "top-timeseries",
			"id" : "top_active_asn",
			"i18n_name" : "graphs.top_customer_asn",
            "time_window" : "day",
		    "time_offset" : "",
			"width" : 12,
			"height" : 4,
			"params" : {
				"url" : "/lua/rest/v2/get/asn/get_top_asn.lua",
				"url_params" : { 
                    "show_as":"all"
                },
				"post_params" : {
					"limit" : 180,
					"version" : 4,
                    "ts_requests": {
						"$CURRENT_IFID$" : {
							"ts_query": "ifid:$IFID$",
							"ts_schema": "top:asn:traffic"
						}
					}
				},
				"source_type" : "interface"
			}
		},
		{
			"component" : "pie",
