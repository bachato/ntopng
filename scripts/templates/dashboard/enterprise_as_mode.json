			"height" : 4,
			"requires" : {
				"modules" : [ "l7_timeseries" ]
			},
			"params" : {
				"url" : "/lua/rest/v2/get/interface/l7/stats.lua",
				"url_params" : {
					"breed" : "true",
					"ndpistats_mode" : "sinceStartup"
				},
				"unit": "bytes"
			}
		},

		{
			"component": "pie",
			"id": "traffic_role_distribution",
			"i18n_name": "if_stats_overview.traffic_role_distribution",
