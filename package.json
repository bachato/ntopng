    "datatables.net-buttons-dt": "^2.3.4",
    "datatables.net-colreorder-dt": "^1.6.1",
    "datatables.net-dt": "^1.11.5",
    "datatables.net-responsive-dt": "^2.4.0",
    "dc": "^4.2.7",
    "dygraphs": "^2.2.1",
