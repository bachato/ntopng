<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>ntopng</title>
    <organization>org.ntop</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true" hostArchitectures="arm64"/>

    <welcome file="Welcome.html" mime-type="text/html"/>
    <conclusion file="Conclusion.html" mime-type="text/html"/>

    <options allow-external-scripts="false"/>

    <allowed-os-versions>
        <os-version min="10.14"/>
    </allowed-os-versions>

    <volume-check>
        <allowed-os-versions>
            <os-version min="10.14"/>
        </allowed-os-versions>
    </volume-check>

    <choices-outline>
        <line choice="default">
            <line choice="org.ntop.ntopng.pkg"/>
        </line>
    </choices-outline>

    <choice id="default"/>

    <choice id="org.ntop.ntopng.pkg" visible="false">
        <pkg-ref id="org.ntop.ntopng"/>
    </choice>

    <pkg-ref id="org.ntop.ntopng" onConclusion="none">org.ntop.ntopng.pkg</pkg-ref>

    <!-- Installation summary messages -->
    <product id="org.ntop.ntopng.pkg"/>

</installer-gui-script>
